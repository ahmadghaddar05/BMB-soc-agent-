# PostgreSQL
POSTGRES_DB=socagent
POSTGRES_USER=socagent
POSTGRES_PASSWORD=replace-with-a-long-random-password

# Phase 1 access boundary
SOC_ADMIN_USERNAME=admin
SOC_ADMIN_PASSWORD=replace-with-at-least-12-characters
SOC_SESSION_SECRET=replace-with-at-least-32-random-characters
SOC_SESSION_TTL_MINUTES=480
# Local Compose uses HTTP. Change to true when the browser origin uses HTTPS.
SOC_COOKIE_SECURE=false
# Optional bearer token for trusted automation (24+ characters recommended)
SOC_API_KEY=
# Optional comma-separated cross-origin browser origins. Same-origin UI needs no value.
SOC_ALLOWED_ORIGINS=

# Alert source: mock, elastic, or wazuh. Mock is the safe local default.
ALERT_SOURCE=mock
# Elastic Security (required only when ALERT_SOURCE=elastic)
ELASTICSEARCH_URL=https://elastictrainee:9200
ELASTIC_ALERT_ALIAS=.alerts-security.alerts-default
ELASTIC_API_KEY=
ELASTIC_VERIFY_TLS=true
# Path inside the API container and matching host path to mount
ELASTIC_CA_CERT=/run/secrets/http_ca.crt
ELASTIC_CA_HOST_PATH=/etc/elasticsearch/certs/http_ca.crt

# Wazuh (used when settings.alert_source is changed to wazuh/mock)
WAZUH_MODE=mock
WAZUH_INDEXER_URL=
WAZUH_INDEXER_USER=admin
WAZUH_INDEXER_PASS=
WAZUH_VERIFY_TLS=false
WAZUH_INDEX=wazuh-alerts-*

# Legacy AI providers are retained only for the disconnected Phase 5 correlation migration.
# Phase 4 chat and triage never fall back to them.
LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1:8b

# Hermes grounded analyst and triage. API_SERVER_KEY on Hermes must match this key.
HERMES_REQUIRED=true
HERMES_API_URL=http://host.docker.internal:8642/v1
HERMES_API_KEY=
HERMES_MODEL=hermes-agent
HERMES_TIMEOUT_MS=180000
HERMES_REQUEST_TIMEOUT_MS=10000
HERMES_MAX_RETRIES=2
HERMES_POLL_INTERVAL_MS=500
HERMES_CAPABILITY_TTL_MS=60000
# Application-owned read-only SOC tool boundary.
HERMES_ANALYST_MAX_TOOL_CALLS=4
HERMES_ANALYST_TIMEOUT_MS=240000
HERMES_TRIAGE_MAX_TOOL_CALLS=3
HERMES_TRIAGE_TIMEOUT_MS=180000
HERMES_TOOL_TIMEOUT_MS=10000
HERMES_TOOL_RESULT_MAX_BYTES=65536
HERMES_STRICT_CAPABILITIES=true
HERMES_ENFORCE_SAFE_TOOLSETS=true
HERMES_REQUIRE_TOOLLESS_PROFILE=true
# Comma-separated Hermes host tools that make the SOC profile fail closed.
HERMES_FORBIDDEN_TOOLS=terminal,execute_code,write_file,patch,delete_file,move_file,browser,web_search,web_extract,delegate_task,cronjob,shell,ssh
