# ── Postgres ──────────────────────────────────────────────────────────────
POSTGRES_DB=socagent
POSTGRES_USER=socagent
POSTGRES_PASSWORD=changeme_strong_password

# ── Wazuh ─────────────────────────────────────────────────────────────────
WAZUH_MODE=real                          # real | mock
WAZUH_INDEXER_URL=https://192.168.1.10:9200
WAZUH_INDEXER_USER=admin
WAZUH_INDEXER_PASS=your_wazuh_password
WAZUH_VERIFY_TLS=false                   # false for self-signed certs
WAZUH_INDEX=wazuh-alerts-*

# ── LLM ───────────────────────────────────────────────────────────────────
LLM_PROVIDER=groq                        # groq | ollama
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ── Scheduler defaults (overridable from Settings UI) ─────────────────────
SCHEDULER_INTERVAL_MINUTES=5
SCHEDULER_LOOKBACK_MINUTES=15
SCHEDULER_MIN_LEVEL=7

# ── Frontend ──────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3000
