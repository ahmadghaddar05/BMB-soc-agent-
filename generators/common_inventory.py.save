def user_doc(user):

    organization = user.get(
        "organization",
        {}
    )

    identity = user.get(
        "identity",
        {}
    )

    authentication = user.get(
        "authentication",
        {}
    )

    access = user.get(
        "access",
        {}
    )

    risk = user.get(
        "risk",
        {}
    )


    return {


        # Identity

        "name":
        user.get(
            "name"
        ),


        "email":
        user.get(
            "email"
        ),


        "id":
        identity.get(
            "immutable_id"
        ),


        "employee_id":
        identity.get(
            "employee_id"
        ),


        "account_type":
        identity.get(
            "account_type",
            "human"
        ),



        # Organization

        "department":
        user.get(
            "department",
            organization.get(
                "department"
            )
        ),


        "business_unit":
        organization.get(
            "business_unit"
        ),


        "job_title":
        organization.get(
            "job_title"
        ),


        "manager":
        organization.get(
            "manager"
        ),


        "location":
        organization.get(
            "location"
        ),



        # Access

        "roles":
        user.get(
            "roles",
            []
        ),


        "privilege":
        access.get(
            "privilege_level",
            "standard"
        ),


        "ad_groups":
        access.get(
            "ad_groups",
            []
        ),


        "cloud_roles":
        access.get(
            "cloud_roles",
            []
        ),



        # Authentication

        "authentication":{


            "mfa_enabled":
            authentication.get(
                "mfa_enabled",
                False
            ),


            "mfa_method":
            authentication.get(
                "mfa_method"
            ),


            "authentication_strength":
            authentication.get(
                "authentication_strength"
            )

        },



        # Risk

        "risk_score":
        risk.get(
            "score",
            0
        ),


        "risk_level":
        risk.get(
            "level"
        ),


        "hr_status":
        risk.get(
            "hr_status"
        )

    }




def workstation_host_doc(user):


    return {

        "name":
        user.get(
            "host"
        ),


        "hostname":
        user.get(
            "host"
        ),


        "id":
        str(
            uuid.uuid5(
                uuid.NAMESPACE_DNS,
                user.get("host")
            )
        ),


        "ip":[

            user.get(
                "ip"
            )

        ],


        "os":{

            "type":
            "windows",

            "family":
            "windows",

            "name":
            "Windows 11 Enterprise",

            "version":
            "23H2"

        }

    }





def server_host_doc(name):


    server=SERVERS[name]


    return {

        "name":
        server["name"],


        "hostname":
        server["name"],


        "id":
        str(
            uuid.uuid5(
                uuid.NAMESPACE_DNS,
                server["name"]
            )
        ),


        "ip":[

            server["ip"]

        ],


        "os":
        server["os"]

    }





def server_ip(name):

    return SERVERS[name]["ip"]





def server_name(name):

    return SERVERS[name]["name"]





def related_for_user_host(

    user,

    extra_ips=None,

    extra_hosts=None,

    extra_users=None

):


    ips=[

        user.get(
            "ip"
        )

    ]


    hosts=[

        user.get(
            "host"
        )

    ]


    users=[

        user.get(
            "name"
        )

    ]



    if extra_ips:

        ips.extend(
            extra_ips
        )


    if extra_hosts:

        hosts.extend(
            extra_hosts
        )


    if extra_users:

        users.extend(
            extra_users
        )


    return {

        "ip":
        list(
            filter(
                None,
                ips
            )
        ),


        "hosts":
        list(
            filter(
                None,
                hosts
            )
        ),


        "user":
        list(
            filter(
                None,
                users
            )
        )

    }
