+                             : [],
+      common_entities:     {
+                             users: Array.isArray(ce.users) ? ce.users.map(String) : [],
+                             hosts: Array.isArray(ce.hosts) ? ce.hosts.map(String) : [],
+                             ips:   Array.isArray(ce.ips)   ? ce.ips.map(String)   : [],
+                           },
